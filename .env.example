# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://postgres:sua_senha@localhost:5432/barbearia

# JWT (gere um string longo e aleatório)
JWT_SECRET=seu_jwt_secreto_muito_seguro_troque_isso

# Mercado Pago (pegue em https://www.mercadopago.com.br/developers)
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx
MP_PUBLIC_KEY=TEST-xxxxxxxxxxxxxxxxxxxx

# URLs da aplicação
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3000

# Admin inicial (use para o primeiro setup via npm run setup)
ADMIN_EMAIL=admin@suabarbearia.com
ADMIN_PASSWORD=trocar_esta_senha_123

# Personalização da barbearia
BARBERSHOP_NAME=Barbearia Classic
BARBERSHOP_PHONE=(11) 99999-9999
BARBERSHOP_ADDRESS=Rua Exemplo, 123 - Bairro, Cidade
BARBERSHOP_INSTAGRAM=@suabarbearia
